# Copy to .env.local for local dev. DO NOT commit .env or .env.local.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (used by Vercel serverless functions at /api/score and /api/chat)
# In Vercel dashboard → Settings → Environment Variables
OPENAI_API_KEY=sk-...

# Server-only. Required for the support chatbot to enforce rate limits and log
# conversations. Get it from Supabase dashboard → Project Settings → API →
# "service_role" secret. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
